{
  "name": "chainmind",
  "version": "0.1.0",
  "description": "AI Agent Billing Proxy on BNB Chain",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest",
    "contract:compile": "cd contracts && npx hardhat compile",
    "contract:test": "cd contracts && npx hardhat test",
    "contract:deploy": "cd contracts && npx hardhat run scripts/deploy.ts --network bsc"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/cors": "^10.0.0",
    "drizzle-orm": "^0.36.0",
    "better-sqlite3": "^11.0.0",
    "ethers": "^6.13.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "drizzle-kit": "^0.28.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "hardhat": "^2.22.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0"
  }
}
