# ===========================================
# ChainMind Configuration
# ===========================================

# BSC (BNB Smart Chain)
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
CONTRACT_ADDRESS=0x_YOUR_DEPLOYED_CONTRACT_ADDRESS
USDC_ADDRESS=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d

# Deposit watcher
DEPOSIT_POLL_INTERVAL_MS=15000
DEPOSIT_CONFIRMATIONS=15

# LLM Provider Keys (upstream — NEVER exposed to agents)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# App
PORT=3000
HOST=0.0.0.0
BASE_URL=https://api.chainmind.xyz
MARKUP_PERCENT=10

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Contract Deployment (only needed for deploying the contract)
# DEPLOYER_PRIVATE_KEY=0x...
